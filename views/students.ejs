<!-- views/students.ejs — The Index Page -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>StartoCode | All Students</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <%- include('partials/header') %>

  <main class="page">
    <div class="info-banner">Info! All students records table</div>

    <!-- Search / filter controls — a normal GET form, so filtering is just a page reload with query params -->
    <form class="filter-bar" action="/students" method="GET">
      <input type="text" name="name" placeholder="Search Record By Name Only" value="<%= filters.name %>" />

      <select name="status">
        <option value="" <%= filters.status === '' ? 'selected' : '' %>>Select Admission Status</option>
        <option value="admitted" <%= filters.status === 'admitted' ? 'selected' : '' %>>Admitted</option>
        <option value="undecided" <%= filters.status === 'undecided' ? 'selected' : '' %>>Undecided</option>
        <option value="rejected" <%= filters.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
      </select>

      <select name="gender">
        <option value="" <%= filters.gender === '' ? 'selected' : '' %>>Select Gender</option>
        <option value="male" <%= filters.gender === 'male' ? 'selected' : '' %>>Male</option>
        <option value="female" <%= filters.gender === 'female' ? 'selected' : '' %>>Female</option>
      </select>

      <input type="number" name="jambScore" placeholder="Enter Jamb Score" value="<%= filters.jambScore %>" />

      <button type="submit" class="btn btn--small">Search</button>
    </form>

    <!-- Students table -->
    <table class="students-table">
      <thead>
        <tr>
          <th>S/n</th>
          <th>Name</th>
          <th>Gender</th>
          <th>Jamb Score</th>
          <th>Admission Status</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% if (students.length === 0) { %>
          <tr>
            <td colspan="6" class="students-table__empty">No student records match your search.</td>
          </tr>
        <% } else { %>
          <% students.forEach(function (student, index) { %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= student.first_name %> <%= student.middle_name ? student.middle_name + ' ' : '' %><%= student.last_name %></td>
              <td><%= student.gender %></td>
              <td><%= student.jamb_score %></td>
              <td>
                <span class="status-pill status-pill--<%= student.status %>"><%= student.status %></span>
              </td>
              <td>
                <a href="/students/<%= student.id %>" class="view-btn" aria-label="View details">&#128065;</a>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </main>

  <%- include('partials/footer') %>

</body>
</html>
