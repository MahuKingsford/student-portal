<!-- views/form.ejs — The Portal Form Page -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>StartoCode | Student Portal Form</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <%- include('partials/header') %>

  <main class="page page--soft">
    <div class="form-card">
      <h1 class="form-card__title">Student Portal Form</h1>
      <p class="form-card__hint">Please fill in all required information</p>

      <!-- Validation errors, if the previous submission failed -->
      <% if (errors && errors.length > 0) { %>
        <div class="alert alert--error" role="alert">
          <strong>We couldn't save your details:</strong>
          <ul>
            <% errors.forEach(function (msg) { %>
              <li><%= msg %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <form id="portal-form" action="/students" method="POST" enctype="multipart/form-data" novalidate>

        <!-- ===================== Personal Information ===================== -->
        <h2 class="form-section-title">Personal Information</h2>

        <div class="form-field">
          <label for="image">Upload Image</label>
          <input type="file" id="image" name="image" accept="image/*" required />
        </div>

        <div class="form-row">
          <div class="form-field">
            <label for="firstName">First Name</label>
            <input type="text" id="firstName" name="firstName" placeholder="Enter First Name"
                   value="<%= old.firstName || '' %>" required />
          </div>
          <div class="form-field">
            <label for="middleName">Middle Name</label>
            <input type="text" id="middleName" name="middleName" placeholder="Enter Middle Name"
                   value="<%= old.middleName || '' %>" />
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <label for="lastName">Last Name</label>
            <input type="text" id="lastName" name="lastName" placeholder="Enter Last Name"
                   value="<%= old.lastName || '' %>" required />
          </div>
          <div class="form-field">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="Enter Email Address"
                   value="<%= old.email || '' %>" required />
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <label for="dob">Date Of Birth</label>
            <input type="date" id="dob" name="dob" value="<%= old.dob || '' %>" required />
          </div>
          <div class="form-field form-field--radios">
            <label>Gender</label>
            <div class="radio-group">
              <label class="radio-option">
                <input type="radio" name="gender" value="male" <%= old.gender === 'male' ? 'checked' : '' %> required />
                Male
              </label>
              <label class="radio-option">
                <input type="radio" name="gender" value="female" <%= old.gender === 'female' ? 'checked' : '' %> />
                Female
              </label>
            </div>
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <label for="phone">Phone Number</label>
            <input type="text" id="phone" name="phone" placeholder="Enter Phone Number"
                   value="<%= old.phone || '' %>" required />
          </div>
          <div class="form-field">
            <label for="address">Address</label>
            <input type="text" id="address" name="address" placeholder="Enter Address"
                   value="<%= old.address || '' %>" required />
          </div>
        </div>

        <div class="form-row">
          <div class="form-field">
            <label for="state">State Of Origin</label>
            <!-- Populated dynamically (asynchronously) by /js/form.js via fetch('/api/states') -->
            <select id="state" name="state" required>
              <option value="" selected disabled>Select State</option>
            </select>
          </div>
          <div class="form-field">
            <label for="lga">Local Government</label>
            <!-- Repopulated dynamically whenever the State above changes -->
            <select id="lga" name="lga" required>
              <option value="" selected disabled>Select Local Government</option>
            </select>
          </div>
        </div>

        <div class="form-field">
          <label for="nextOfKin">Next Of Kin</label>
          <input type="text" id="nextOfKin" name="nextOfKin" placeholder="Enter The Name Of Next Of Kin"
                 value="<%= old.nextOfKin || '' %>" required />
        </div>

        <!-- ===================== Academics Related Information ===================== -->
        <h2 class="form-section-title">Academics Related Information</h2>

        <div class="form-field">
          <label for="jambScore">Jamb Score</label>
          <input type="number" id="jambScore" name="jambScore" placeholder="Enter Jamb Score" min="0" max="400"
                 value="<%= old.jambScore || '' %>" required />
        </div>

        <button type="submit" class="btn btn--primary btn--block">Submit</button>
      </form>
    </div>
  </main>

  <%- include('partials/footer') %>

  <script src="/js/form.js"></script>
</body>
</html>
